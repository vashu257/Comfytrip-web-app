rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================
    // 🔹 REQUESTS
    // ==========================
    match /requests/{requestId} {

      // Only logged-in users can create
      allow create: if request.auth != null;

      // Only logged-in users can read
      allow read: if request.auth != null;

      // Only owner can update/delete
      allow update, delete: if request.auth.uid == resource.data.uid;
    }


    // ==========================
    // 🔹 MATCHES
    // ==========================
    match /matches/{matchId} {

      // Only users in match can read
      allow read: if request.auth.uid in resource.data.users;

      // Only users involved can create/update
      allow write: if request.auth.uid in request.resource.data.users;
    }


    // ==========================
    // 🔹 CHAT MESSAGES
    // ==========================
    match /chats/{matchId}/messages/{messageId} {

      // Only matched users can read/write chat
      allow read, write: if request.auth.uid in
        get(/databases/$(database)/documents/matches/$(matchId)).data.users;
    }

  }
}